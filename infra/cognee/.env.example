# Cognee sidecar environment template (cognee 1.0.8 verified env-var names).
# Copy to infra/cognee/.env, fill in keys, never commit the real .env.

# ── HTTP server ────────────────────────────────────────────────────────────
HTTP_API_HOST=127.0.0.1
HTTP_API_PORT=8765

# ── Multi-user posture (Phase 5b) ─────────────────────────────────────────
# Cognee enforces dataset isolation per user when ACL is on. Phase 5b
# leans on this: every dev project gets its own cognee user (and JWT),
# so cross-project recall is blocked by permissions.
#
# default_user@example.com / default_password is created automatically
# at sidecar startup as a superuser; the FAG main process logs in as
# this user for the personal scope. Dev-project users are regular
# (non-superuser) and only see their own dev_<id> dataset.
ENABLE_BACKEND_ACCESS_CONTROL=true
REQUIRE_AUTHENTICATION=false
CACHING=false

# ── State directory (gitignored). start.sh defaults to infra/cognee/data ──
# COGNEE_SYSTEM_ROOT_DIRECTORY=

# ── LLM (extraction / cognification / search) ──────────────────────────────
# When LLM_PROVIDER=anthropic, cognee uses the Anthropic SDK directly via
# `instructor` (NOT litellm), so the model id must be the Anthropic-native
# name with no `anthropic/` prefix.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_COMPLETION_TOKENS=4096

# Cognee uses BAML for some structured-output tasks; defaults to openai/gpt-5-mini.
# Leaving these unset keeps that default — needs OPENAI_API_KEY below.
# BAML_LLM_PROVIDER=
# BAML_LLM_MODEL=
# BAML_LLM_API_KEY=

# ── Embedding ──────────────────────────────────────────────────────────────
# Spike-2 verified: openai/text-embedding-3-small works out of the box.
# Gemini (`gemini/text-embedding-004`) timed out cognee's startup connection
# probe — needs more investigation, deferred. To try again later, set:
#   EMBEDDING_PROVIDER=gemini
#   EMBEDDING_MODEL=gemini/text-embedding-004
#   EMBEDDING_API_KEY=<google key>
#   EMBEDDING_DIMENSIONS=768
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=1536

# ── Vector store ───────────────────────────────────────────────────────────
# cognee 1.0.8 only ships handlers for lancedb / pgvector / chromadb in the
# default install. We use lancedb — file-backed, no extra service to run,
# state lives in infra/cognee/data/. FAG's main Qdrant collection
# (file_agent_v2) is unaffected.
VECTOR_DB_PROVIDER=lancedb
# VECTOR_DB_URL / VECTOR_DB_KEY unused for lancedb.

# ── Fallback OpenAI key (for BAML / transcription / safety net) ────────────
OPENAI_API_KEY=
