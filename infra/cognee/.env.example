# Cognee sidecar environment template.
# Copy to infra/cognee/.env, fill in keys, never commit the real .env.

# ── HTTP server ────────────────────────────────────────────────────────────
HTTP_API_HOST=127.0.0.1
HTTP_API_PORT=8765

# ── Single-user posture (see Decision #8 in plan) ──────────────────────────
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false

# ── State directory (gitignored). start.sh defaults to infra/cognee/data ──
# COGNEE_SYSTEM_ROOT_DIRECTORY=

# ── LLM keys (mirror values from FAG main .env) ────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
# OPENAI_API_KEY=  # only needed if cognee falls back to OpenAI embeddings

# ── LLM / embedding choice ─────────────────────────────────────────────────
# Exact env var names and supported model ids will be confirmed in spike-2.
# Cognee's defaults skew toward OpenAI; values below are the intent we target.
LLM_PROVIDER=anthropic
LLM_MODEL=anthropic/claude-sonnet-4-20250514
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── Vector store (cognee owns its own collection — separate from FAG) ──────
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://127.0.0.1:6333
VECTOR_DB_KEY=

# ── Optional: bound cost / latency on cognify ──────────────────────────────
# COGNIFY_MAX_TOKENS=4000
