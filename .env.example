# ============================================
# FileAgent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Telegram Bot [REQUIRED] ──────────────────
TELEGRAM_BOT_TOKEN=                    # Bot token from @BotFather
TELEGRAM__OWNER_ID=                    # Your Telegram user ID

# ── LLM Providers (at least one) ─────────────
ANTHROPIC_API_KEY=                     # sk-ant-... (Claude)
OPENAI_API_KEY=                        # sk-... (GPT)

# ── Google [REQUIRED for embeddings] ─────────
GOOGLE_API_KEY=                        # AIza... (Gemini Embedding)

# ── Qdrant (auto-set by Docker Compose) ──────
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__API_KEY=

# ── Web Dashboard Auth ───────────────────────
WEB__SESSION_SECRET=change-me-random-32-chars
WEB__LOGIN=admin@example.com
WEB__PASSWORD_HASH=
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"

# ── Optional ─────────────────────────────────
TAVILY_API_KEY=                        # Web research for Insights
