# ============================================
# FileAgent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Telegram Bot [REQUIRED] ──────────────────
TELEGRAM_BOT_TOKEN=                    # Bot token from @BotFather
TELEGRAM__OWNER_ID=                    # Your Telegram user ID
TELEGRAM__PIN_CODE=                    # 4-6 digit PIN for critical ops (unlock, delete)
TELEGRAM__AUTO_DELETE_SECONDS=120      # Auto-delete bot replies (0 = off)
# TELEGRAM__WEBHOOK_URL=              # HTTPS URL for webhook mode (leave empty for polling)
# TELEGRAM__WEBHOOK_SECRET=           # Secret token for webhook verification

# ── LLM Providers (at least one) ─────────────
ANTHROPIC_API_KEY=                     # sk-ant-... (Claude)
OPENAI_API_KEY=                        # sk-... (GPT)

# ── Google [REQUIRED for embeddings] ─────────
GOOGLE_API_KEY=                        # AIza... (Gemini Embedding)

# ── Qdrant (auto-set by Docker Compose) ──────
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__API_KEY=

# ── Web Dashboard Auth ───────────────────────
WEB__SESSION_SECRET=change-me-random-32-chars
WEB__LOGIN=admin@example.com
WEB__PASSWORD_HASH=
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"

# ── Encryption at Rest (optional) ───────────
# При запуске система попросит мастер-пароль (ключ нигде не хранится)
# MASTER_PASSWORD=                     # Только для Docker/автозапуска (небезопасно в файле!)
ENCRYPTION__FILES=false                # Encrypt files on disk
ENCRYPTION__DATABASE=false             # Encrypt sensitive DB columns
ENCRYPTION__QDRANT_STRIP=false         # Remove text from Qdrant payload

# ── Optional ─────────────────────────────────
TAVILY_API_KEY=                        # Web research for Insights
