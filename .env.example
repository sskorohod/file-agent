# Smart Storage — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM__OWNER_ID=             # Auto-detected on first /start
TELEGRAM__WEBHOOK_SECRET=       # Auto-generated if empty
TELEGRAM__PIN_CODE=             # 4-6 digit PIN for critical ops

# ── LLM Providers ──
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Qdrant (Vector DB) ──
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__API_KEY=

# ── Web Auth ──
WEB__SESSION_SECRET=            # Auto-generated if empty
WEB__LOGIN=admin
WEB__PASSWORD_HASH=             # Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"

# ── Encryption at Rest ──
MASTER_PASSWORD=                # Master password for AES-256-GCM encryption
ENCRYPTION__FILES=true
ENCRYPTION__DATABASE=true
ENCRYPTION__QDRANT_STRIP=true
KEY_FILE=                       # Optional: path to key file for 2FA
